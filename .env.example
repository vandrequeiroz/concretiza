# Copie este arquivo para .env e preencha os valores

# Porta do servidor (padrão: 3000)
PORT=3000

# Segredo da sessão — use uma string longa e aleatória em produção
SESSION_SECRET=troque-por-uma-chave-secreta-longa

# Credenciais do admin inicial (usadas apenas na primeira execução)
ADMIN_EMAIL=admin@concretiza.com.br
ADMIN_PASSWORD=troque-por-uma-senha-segura
